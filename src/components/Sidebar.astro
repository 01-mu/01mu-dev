---
import AuthorCard from "./AuthorCard.astro";

const { variant = "home" } = Astro.props;
---

<aside
  class:list={[
    "col-[3] self-start max-tablet:col-auto max-mobile:order-2 max-mobile:mt-6 max-mobile:flex max-mobile:w-full max-mobile:justify-center",
    variant === "post" &&
      "sticky top-[5.5rem] flex flex-col max-mobile:static max-mobile:items-center",
  ]}
>
  <AuthorCard />
  <slot />
</aside>
