---
type TocHeading = {
  depth: number;
  slug: string;
  text: string;
};

const {
  headings = [],
  levels = [2, 3],
  title = "On this page",
  contained = false,
} = Astro.props as {
  headings?: TocHeading[];
  levels?: number[];
  title?: string;
  contained?: boolean;
};

const visibleHeadings = headings.filter((heading) =>
  levels.includes(heading.depth),
);
const navClass = contained
  ? "max-h-none overflow-visible pr-0"
  : "max-h-[calc(100vh-16rem)] overflow-y-auto pr-2";
const linkClass =
  "relative rounded-md px-[0.45rem] py-[0.15rem] text-inherit transition-[color,opacity,background-color] duration-150";
---

{visibleHeadings.length > 0 && (
  <div class="toc-root">
    <nav class:list={["toc", navClass]} aria-label="Table of contents">
      <p
        class="m-0 mb-3 text-[0.85rem] tracking-[0.04em] text-[var(--muted)] uppercase max-[720px]:hidden"
      >
        {title}
      </p>
      <ul class="m-0 grid list-none gap-[0.35rem] p-0 text-[0.9rem] text-[var(--muted)]">
        <li class="min-[721px]:hidden">
          <a href="#top" data-toc-link="top" class={linkClass}>Return to top</a>
        </li>
        {visibleHeadings.map((heading) => (
          <li class:list={[heading.depth === 3 && "pl-[0.9rem]"]}>
            <a
              href={`#${heading.slug}`}
              data-toc-link={heading.slug}
              class={linkClass}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}

<script is:inline>
  const initRoot = (root) => {
    if (!root || root.dataset.tocInitialized === "true") {
      return;
    }
    const isInline = Boolean(root.closest(".toc-inline"));
    const isMobile = window.matchMedia("(max-width: 720px)").matches;
    if (isInline && isMobile) {
      return;
    }
    const tocContainer = root.querySelector(".toc");
    let scrollContainer = tocContainer;
    const links = Array.from(
      root.querySelectorAll("[data-toc-link]"),
    );
    const headings = links
      .map((link) => document.getElementById(link.dataset.tocLink))
      .filter(Boolean);

    if (links.length === 0 || headings.length === 0) {
      return;
    }

    root.dataset.tocInitialized = "true";

    if (
      scrollContainer &&
      scrollContainer.scrollHeight <= scrollContainer.clientHeight
    ) {
      const panel = root.closest(".toc-panel");
      if (panel instanceof HTMLElement) {
        scrollContainer = panel;
      }
    }

    let lastActiveIndex = -1;
    let scrollAnimId = null;
    const smoothScrollTo = (targetTop) => {
      if (scrollAnimId) {
        cancelAnimationFrame(scrollAnimId);
      }
      const startTop = scrollContainer.scrollTop;
      const delta = targetTop - startTop;
      const duration = 420;
      const startTime = performance.now();

      const step = (now) => {
        const t = Math.min(1, (now - startTime) / duration);
        const eased = 1 - Math.pow(1 - t, 4);
        scrollContainer.scrollTop = startTop + delta * eased;
        if (t < 1) {
          scrollAnimId = requestAnimationFrame(step);
        } else {
          scrollAnimId = null;
        }
      };

      scrollAnimId = requestAnimationFrame(step);
    };
    const pad = 48;
    const activeClasses = [
      "bg-[color-mix(in_srgb,var(--ink)_8%,transparent)]",
      "font-semibold",
      "text-[var(--ink)]",
    ];
    const pastClasses = [
      "text-[var(--ink)]",
      "opacity-65",
    ];
    const setActiveIndex = (activeIndex) => {
      links.forEach((link, index) => {
        activeClasses.forEach((className) => {
          link.classList.toggle(className, index === activeIndex);
        });
        pastClasses.forEach((className) => {
          link.classList.toggle(className, index < activeIndex);
        });
      });

      if (activeIndex !== lastActiveIndex) {
        const activeLink = links[activeIndex];
        if (scrollContainer && activeLink) {
          const containerRect = scrollContainer.getBoundingClientRect();
          const linkRect = activeLink.getBoundingClientRect();
          const topEdge = containerRect.top + pad;
          const bottomEdge = containerRect.bottom - pad;

          if (linkRect.top < topEdge) {
            smoothScrollTo(
              scrollContainer.scrollTop - (topEdge - linkRect.top),
            );
          } else if (linkRect.bottom > bottomEdge) {
            smoothScrollTo(
              scrollContainer.scrollTop + (linkRect.bottom - bottomEdge),
            );
          }
        }
        lastActiveIndex = activeIndex;
      }
    };

    let offsets = [];
    const updateOffsets = () => {
      offsets = headings.map(
        (heading) => heading.getBoundingClientRect().top + window.scrollY,
      );
    };

    const updateActive = () => {
      const targetY = window.scrollY + window.innerHeight * 0.3;
      let activeIndex = 0;

      offsets.forEach((offset, index) => {
        if (offset <= targetY) {
          activeIndex = index;
        }
      });

      setActiveIndex(activeIndex);
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) {
        return;
      }
      ticking = true;
      window.requestAnimationFrame(() => {
        updateActive();
        ticking = false;
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      updateOffsets();
      onScroll();
    });
    updateOffsets();
    updateActive();
  };

  const initAll = () => {
    document.querySelectorAll(".toc-root").forEach(initRoot);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAll, { once: true });
  } else {
    initAll();
  }
</script>
