---
import "../styles/global.css";

const { title, description, mainClass = "main--page" } = Astro.props;
const siteTitle = "mu log";
const siteTagline = "Designing systems from nothing(mu / 無).";
const pageTitle = title ? `${title} · ${siteTitle}` : siteTitle;
const pageDescription = description ?? siteTagline;
const mainClasses = [
  mainClass,
  "mx-auto min-h-[70vh] flex-1 bg-[var(--bg-paper)]",
  mainClass === "main--post" &&
    "max-w-none bg-transparent px-0 pt-6 pb-[3.2rem] max-[720px]:pt-10 max-[720px]:pb-[2.8rem]",
  mainClass === "main--home" &&
    "max-w-none bg-transparent px-0 pt-6 pb-[3.2rem] max-[1024px]:m-0 max-[720px]:pt-[1.2rem] max-[720px]:pb-[2.8rem]",
  mainClass === "main--page" &&
    "max-w-none px-0 pt-6 pb-[3.2rem] max-[720px]:pt-[1.2rem] max-[720px]:pb-[2.8rem]",
  !["main--post", "main--home", "main--page"].includes(mainClass) &&
    "max-w-[76ch] px-6 pt-14 pb-[3.2rem] max-[720px]:px-5 max-[720px]:pt-10 max-[720px]:pb-[2.8rem]",
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <header
      class="flex w-full items-baseline justify-between gap-4 px-8 pt-[1.2rem] max-[720px]:flex-col max-[720px]:items-start max-[720px]:gap-3 max-[720px]:px-6 max-[720px]:pt-5"
    >
      <div class="flex flex-col gap-[0.06rem] pb-4 text-left">
        <a
          href="/"
          class="text-[1.8rem] font-semibold tracking-[0.01em]"
          aria-label="mu log"
        >
          {siteTitle}
        </a>
        <div class="text-[0.95rem] text-[var(--muted)]">{siteTagline}</div>
      </div>
      <nav
        class="flex justify-end gap-4 text-[0.95rem] max-[720px]:flex-wrap max-[720px]:justify-start"
      >
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/tags">Tags</a>
      </nav>
    </header>
    <main class:list={mainClasses}>
      <slot />
    </main>
    <footer
      class="mx-auto mb-10 max-w-[76ch] px-6 text-center text-[0.85rem] text-[var(--muted)]"
    >
      <span>Quiet notes for long-form thinking.</span>
    </footer>
  </body>
</html>
