---
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import Sidebar from "../components/Sidebar.astro";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  title: string;
  date: string | Date;
  tags?: string[];
  description?: string;
  headings?: Heading[];
};

const {
  title,
  date,
  tags = [],
  description,
  headings = [],
} = Astro.props as Props;
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const proseMetaClass = "text-[0.95rem] text-muted";
const pageTitleClass = "mt-0";
const tagListClass = "flex flex-wrap gap-x-[0.6rem] gap-y-[0.4rem]";
const tagPillClass = "text-[0.85rem] text-muted";
---

<BaseLayout title={title} description={description} mainClass="main--post">
  <div
    class="grid grid-cols-[minmax(0,1fr)_minmax(0,82ch)_220px_minmax(0,1fr)] items-start gap-10 max-mobile:flex max-mobile:flex-col"
  >
    <article
      class="col-[2] min-w-0 bg-paper px-11 pt-10 pb-[2.6rem] [&_li+li]:mt-2 [&_ol]:my-5 [&_ol]:list-decimal [&_ol]:pl-[1.2rem] [&_ul]:my-5 [&_ul]:list-disc [&_ul]:pl-[1.2rem] max-mobile:order-1 max-mobile:col-auto max-mobile:px-6 max-mobile:pt-8 max-mobile:pb-9"
      id="top"
      lang="en"
    >
      <p class={proseMetaClass}>{formattedDate}</p>
      <h1 class={pageTitleClass}>{title}</h1>
      {
        tags.length > 0 && (
          <div class={tagListClass}>
            {tags.map((tag) => (
              <a class={tagPillClass} href={`/tags/${encodeURIComponent(tag)}`}>
                {tag}
              </a>
            ))}
          </div>
        )
      }
      <slot />
    </article>
    <Sidebar variant="post">
      <div
        class="my-0 mt-6 mb-5 h-px bg-border max-mobile:hidden"
        aria-hidden="true"
      >
      </div>
      <div
        class="toc-panel fixed top-[4.5rem] right-4 left-4 z-20 hidden max-h-[60vh] overflow-y-auto rounded-[10px] border border-border bg-paper p-4 shadow-[0_12px_30px_rgba(28,42,51,0.15)]"
        id="mobile-toc-panel"
      >
        <TableOfContents headings={headings} contained />
      </div>
      <div class="toc-inline hidden desktop:block">
        <TableOfContents headings={headings} />
      </div>
    </Sidebar>
  </div>
  <button
    class="toc-toggle fixed top-4 right-4 z-[21] hidden items-center gap-[0.35rem] rounded-full border border-border bg-paper px-3 py-[0.45rem] text-[0.85rem] text-ink max-mobile:inline-flex"
    type="button"
    aria-controls="mobile-toc-panel"
    aria-expanded="false"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4">
      <path
        fill="currentColor"
        d="M4 6.5h16v2H4v-2Zm0 5h10v2H4v-2Zm0 5h13v2H4v-2Z"></path>
    </svg>
    Contents
  </button>
</BaseLayout>

<script>
  const toggle = document.querySelector(".toc-toggle");
  const panel = document.querySelector("#mobile-toc-panel");

  if (toggle && panel) {
    const update = (open = false) => {
      document.body.classList.toggle("toc-open", open);
      panel.classList.toggle("hidden", !open);
      panel.classList.toggle("block", open);
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    };

    toggle.addEventListener("click", () => {
      const open = document.body.classList.contains("toc-open");
      update(!open);
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }
      if (!document.body.classList.contains("toc-open")) {
        return;
      }
      if (panel.contains(target) || toggle.contains(target)) {
        return;
      }
      update(false);
    });

    panel.addEventListener("click", (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest("[data-toc-link]")) {
        update(false);
      }
    });
  }
</script>
