---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";

const homeLayoutClass =
  "grid grid-cols-[minmax(0,1fr)_minmax(0,82ch)_220px_minmax(0,1fr)] items-start gap-10 max-[1024px]:grid-cols-[minmax(0,1fr)] max-[720px]:flex max-[720px]:flex-col";
const homeContentClass =
  "col-[2] min-w-0 bg-[var(--bg-paper)] px-11 pt-10 pb-[2.6rem] max-[1024px]:col-auto max-[1024px]:w-full max-[720px]:order-1 max-[720px]:px-6 max-[720px]:pt-8 max-[720px]:pb-9";
---

<BaseLayout title="About" mainClass="main--home">
  <div class={homeLayoutClass}>
    <section class={homeContentClass}>
      {/*
        Reserve the "about-icon" slot for future section numbering once the About
        page grows. Please ask before re-enabling or repurposing this element.
      */}
      {/* <div class="about-icon" aria-hidden="true">01</div> */}
      <h1 class="page-title">About</h1>
      <p>
        I write and build under the name mu.<br />
        I am a software engineer from Hokkaido.<br />
        Most of my work in Sapporo and Tokyo has been in business application development.
      </p>
      <p>
        <strong>Languages</strong>
        <br />
        Java, C#, PHP, JavaScript, TypeScript, Python
      </p>
      <p>
        <strong>Frameworks</strong>
        <br />
        Spring Boot, ASP.NET Core, Laravel, Vue
      </p>
      <p>
        Outside of work, I like to explore a wider range of technologies.
        <br />
        My current goal is to build a specialty people immediately associate with mu.
      </p>
    </section>
    <Sidebar />
  </div>
</BaseLayout>
