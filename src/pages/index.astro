---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import { getAllTags, getVisiblePosts } from "../utils/posts";

const posts = await getVisiblePosts();
const tags = getAllTags(posts);
const homeLayoutClass =
  "grid grid-cols-[minmax(0,1fr)_minmax(0,82ch)_220px_minmax(0,1fr)] items-start gap-10 max-[1024px]:grid-cols-[minmax(0,1fr)] max-[720px]:flex max-[720px]:flex-col";
const homeContentClass =
  "col-[2] min-w-0 bg-[var(--bg-paper)] px-11 pt-8 pb-[2.6rem] max-[1024px]:col-auto max-[1024px]:w-full max-[720px]:order-1 max-[720px]:px-6 max-[720px]:pt-6 max-[720px]:pb-9";
---

<BaseLayout description="Quiet notes for long-form thinking." mainClass="main--home">
  <div class={homeLayoutClass}>
    <section class={homeContentClass}>
      <h1 class="page-title">Latest writing</h1>
      {posts.length === 0 ? (
        <p class="prose-meta">No published posts yet.</p>
      ) : (
        <ul class="m-0 list-none p-0">
          {posts.map((post) => (
            <li class="border-b border-[var(--border)] py-5">
              <a
                class="block text-[1.1rem] font-[560] max-[720px]:hover:border-b-transparent max-[720px]:focus-visible:border-b-transparent"
                href={`/posts/${post.slug}`}
              >
                {post.data.title}
              </a>
              <div class="text-[0.9rem] text-[var(--muted)]">
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
                {post.data.tags.length > 0 && (
                  <span>
                    {" · "}
                    {post.data.tags.join(", ")}
                  </span>
                )}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
    <Sidebar>
      {tags.length > 0 && (
        <>
          <div
            class="my-0 mt-6 mb-5 h-px bg-[var(--border)] max-[720px]:hidden"
            aria-hidden="true"
          >
          </div>
          <div class="mt-[1.2rem] grid gap-2 max-[720px]:hidden">
            <p class="m-0 text-[0.8rem] tracking-[0.04em] text-[var(--muted)] uppercase">Tags</p>
            <div class="tag-list">
              {tags.map(({ tag, count }) => (
                <a class="tag-pill" href={`/tags/${encodeURIComponent(tag)}`}>
                  {tag} ({count})
                </a>
              ))}
            </div>
          </div>
        </>
      )}
    </Sidebar>
  </div>
</BaseLayout>
