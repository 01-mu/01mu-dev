---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import { getAllTags, getVisiblePosts } from "../utils/posts";

const posts = await getVisiblePosts();
const tags = getAllTags(posts);
const homeLayoutClass =
  "grid grid-cols-[minmax(0,1fr)_minmax(0,82ch)_220px_minmax(0,1fr)] items-start gap-10 max-tablet:grid-cols-[minmax(0,1fr)] max-mobile:flex max-mobile:flex-col";
const homeContentClass =
  "col-[2] min-w-0 bg-paper px-11 pt-8 pb-[2.6rem] max-tablet:col-auto max-tablet:w-full max-mobile:order-1 max-mobile:px-6 max-mobile:pt-6 max-mobile:pb-9";
const proseMetaClass = "text-[0.95rem] text-muted";
const pageTitleClass = "mt-0";
const tagListClass = "flex flex-wrap gap-x-[0.6rem] gap-y-[0.4rem]";
const tagPillClass = "text-[0.85rem] text-muted";
---

<BaseLayout description="Quiet notes for long-form thinking." mainClass="main--home">
  <div class={homeLayoutClass}>
    <section class={homeContentClass}>
      <h1 class={pageTitleClass}>Latest writing</h1>
      {posts.length === 0 ? (
        <p class={proseMetaClass}>No published posts yet.</p>
      ) : (
        <ul class="m-0 list-none p-0">
          {posts.map((post) => (
            <li class="border-b border-border py-5">
              <a
                class="block text-[1.1rem] font-[560] max-mobile:hover:border-b-transparent max-mobile:focus-visible:border-b-transparent"
                href={`/posts/${post.slug}`}
              >
                {post.data.title}
              </a>
              <div class="text-[0.9rem] text-muted">
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
                {post.data.tags.length > 0 && (
                  <span>
                    {" · "}
                    {post.data.tags.join(", ")}
                  </span>
                )}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
    <Sidebar>
      {tags.length > 0 && (
        <>
          <div
            class="my-0 mt-6 mb-5 h-px bg-border max-mobile:hidden"
            aria-hidden="true"
          >
          </div>
          <div class="mt-[1.2rem] grid gap-2 max-mobile:hidden">
            <p class="m-0 text-[0.8rem] tracking-[0.04em] text-muted uppercase">Tags</p>
            <div class={tagListClass}>
              {tags.map(({ tag, count }) => (
                <a class={tagPillClass} href={`/tags/${encodeURIComponent(tag)}`}>
                  {tag} ({count})
                </a>
              ))}
            </div>
          </div>
        </>
      )}
    </Sidebar>
  </div>
</BaseLayout>
