---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Sidebar from "../../components/Sidebar.astro";
import { getAllTags, getVisiblePosts } from "../../utils/posts";

const posts = await getVisiblePosts();
const tags = getAllTags(posts);
const homeLayoutClass =
  "grid grid-cols-[minmax(0,1fr)_minmax(0,82ch)_220px_minmax(0,1fr)] items-start gap-10 max-[1024px]:grid-cols-[minmax(0,1fr)] max-[720px]:flex max-[720px]:flex-col";
const homeContentClass =
  "col-[2] min-w-0 bg-[var(--bg-paper)] px-11 pt-10 pb-[2.6rem] max-[1024px]:col-auto max-[1024px]:w-full max-[720px]:order-1 max-[720px]:px-6 max-[720px]:pt-8 max-[720px]:pb-9";
---

<BaseLayout title="Tags" mainClass="main--home">
  <div class={homeLayoutClass}>
    <section class={homeContentClass}>
      <h1 class="page-title">Tags</h1>
      <div class="tag-list">
        {tags.length === 0 && <span class="prose-meta">No tags yet.</span>}
        {tags.map(({ tag, count }) => (
          <a class="tag-pill" href={`/tags/${encodeURIComponent(tag)}`}>
            {tag} ({count})
          </a>
        ))}
      </div>
    </section>
    <Sidebar />
  </div>
</BaseLayout>
